---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"contributors">;
  featured?: boolean;
  delay?: number;
}

const {
  entry,
  featured = false,
  delay = 0
} = Astro.props as Props;
const baseUrl = import.meta.env.BASE_URL;

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "short"
  }).format(value);
---

<article
  class:list={[
    "card-shell contributor-card reveal flex h-full flex-col gap-4",
    featured ? "contributor-card-featured" : ""
  ]}
  style={`--delay:${delay}ms`}
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-4">
      {entry.data.avatar && (
        <span class="avatar-frame">
          <img
            src={entry.data.avatar}
            alt={`${entry.data.name} 头像`}
            loading="lazy"
            class="h-14 w-14 object-cover ring-1 ring-black/5"
          />
        </span>
      )}

      <div class="min-w-0">
        <h3 class="display truncate text-3xl leading-none md:text-[2.1rem]">{entry.data.name}</h3>
        <p class="mt-1 text-sm font-semibold uppercase tracking-[0.08em] text-[var(--primary)]">
          {entry.data.role}
        </p>
        {entry.data.location && <p class="text-sm text-[var(--muted)]">{entry.data.location}</p>}
      </div>
    </div>

    {featured && <span class="badge-featured">Featured</span>}
  </div>

  <p class="text-sm leading-7 text-[var(--muted)]">{entry.data.summary}</p>

  {entry.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {entry.data.tags.map((tag) => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>
  )}

  <div class="mt-auto">
    <p class="text-sm text-[var(--muted)]">加入时间：{formatDate(entry.data.joinedAt)}</p>

    <div class="mt-3 flex flex-wrap gap-2">
      <a class="chip chip-primary" href={`${baseUrl}contributors/${entry.slug}/`}>查看详情页</a>

      {entry.data.github && (
        <a class="chip" href={entry.data.github} target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      )}

      {entry.data.website && (
        <a class="chip" href={entry.data.website} target="_blank" rel="noopener noreferrer">
          个人主页
        </a>
      )}
    </div>
  </div>
</article>
